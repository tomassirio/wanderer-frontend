# Environment Configuration Template
# Copy this file to .env.dev or .env.prod and fill in your values

# Domain without protocol
DOMAIN=your-domain.com

# Protocols for Web (use http/ws for dev, https/wss for prod)
WEB_HTTP_PROTOCOL=https
WEB_WS_PROTOCOL=wss

# Protocols for Android Emulator (use http/ws for dev with self-signed certs)
ANDROID_HTTP_PROTOCOL=http
ANDROID_WS_PROTOCOL=ws

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Android Emulator Device ID (optional, use 'flutter devices' to find yours)
# ANDROID_DEVICE_ID=emulator-5554

# API Paths (backend uses /api/1/ versioning)
API_PATH=/api/1
